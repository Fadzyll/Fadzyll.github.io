---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo">
			<span class="logo-bracket">&lt;</span>{SITE_TITLE}<span class="logo-bracket">/&gt;</span>
		</a>
		<button class="menu-toggle" id="menuToggle" aria-label="Toggle menu">
			<span></span><span></span><span></span>
		</button>
		<div class="nav-links" id="navLinks">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/career">Career</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
			<button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
				<svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
				</svg>
				<svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
				</svg>
			</button>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		margin: 0;
		padding: 0 2em;
		background: rgba(5, 10, 20, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
		height: 64px;
		gap: 1em;
	}

	.logo {
		font-size: 1.1em;
		font-weight: 700;
		color: var(--white);
		text-decoration: none;
		white-space: nowrap;
		flex-shrink: 0;
	}

	.logo-bracket {
		color: var(--accent);
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}

	.nav-links :global(a) {
		display: inline-block;
		padding: 0.4em 0.75em;
		color: var(--white-muted);
		text-decoration: none;
		font-size: 0.9em;
		font-weight: 500;
		border-radius: 6px;
		border-bottom: 2px solid transparent;
		transition: color 0.2s ease, background 0.2s ease;
		white-space: nowrap;
	}

	.nav-links :global(a:hover) {
		color: var(--white);
		background: var(--accent-glow);
	}

	.nav-links :global(a.active) {
		color: var(--accent);
		border-bottom-color: var(--accent);
		font-weight: 600;
		text-decoration: none;
	}

	/* Theme toggle */
	.theme-toggle {
		background: none;
		border: 1px solid var(--border);
		border-radius: 8px;
		color: var(--white-muted);
		cursor: pointer;
		padding: 0.4em;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: color 0.2s, border-color 0.2s, background 0.2s;
		flex-shrink: 0;
	}

	.theme-toggle:hover {
		color: var(--accent);
		border-color: var(--accent);
		background: var(--accent-glow);
	}

	/* Show sun in dark mode, moon in light mode */
	.icon-moon { display: none; }
	.icon-sun { display: block; }

	:global(html.light) .icon-moon { display: block; }
	:global(html.light) .icon-sun { display: none; }

	/* Mobile */
	.menu-toggle {
		display: none;
		flex-direction: column;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5em;
	}

	.menu-toggle span {
		display: block;
		width: 24px;
		height: 2px;
		background: var(--white-muted);
		border-radius: 2px;
		transition: all 0.3s ease;
	}

	@media (max-width: 720px) {
		header {
			padding: 0 1em;
		}

		.menu-toggle {
			display: flex;
		}

		.nav-links {
			display: none;
			position: absolute;
			top: 64px;
			left: 0;
			right: 0;
			flex-direction: column;
			align-items: stretch;
			background: rgba(5, 10, 20, 0.97);
			border-bottom: 1px solid var(--border);
			padding: 1em;
			gap: 0.25em;
		}

		.nav-links.open {
			display: flex;
		}

		.nav-links :global(a) {
			padding: 0.75em 1em !important;
			font-size: 0.95em !important;
		}

}
</style>

<script>
	// Mobile menu
	const menuToggle = document.getElementById('menuToggle');
	const navLinks = document.getElementById('navLinks');

	menuToggle?.addEventListener('click', () => {
		navLinks?.classList.toggle('open');
	});

	navLinks?.querySelectorAll('a').forEach((link) => {
		link.addEventListener('click', () => {
			navLinks.classList.remove('open');
		});
	});

	// Theme toggle
	const themeToggle = document.getElementById('themeToggle');
	const html = document.documentElement;

	// Load saved preference
	if (localStorage.getItem('theme') === 'light') {
		html.classList.add('light');
	}

	themeToggle?.addEventListener('click', () => {
		html.classList.toggle('light');
		localStorage.setItem('theme', html.classList.contains('light') ? 'light' : 'dark');
	});
</script>
