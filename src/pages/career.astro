---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Career — Fadzyll" description="Work experience, academic journey, achievements, and what's next for Fadzil Bin Ismail." />
	</head>
	<body>
		<Header />
		<main>

			<!-- Hero -->
			<section class="page-hero">
				<p class="section-label reveal">// career</p>
				<h1 class="reveal reveal-delay-1">My <span class="accent">Journey</span></h1>
				<p class="lead reveal reveal-delay-2">
					From a curious student in Sabah to a software engineer in the making —
					here's my professional story, academic path, and where I'm heading next.
				</p>
				<div class="hero-actions reveal reveal-delay-3">
					<a href="/Resume Latest.pdf" download class="btn btn-primary">Download CV</a>
					<a href="/contact" class="btn btn-outline">Get in Touch</a>
				</div>
			</section>

			<!-- Work Experience -->
			<section class="section">
				<p class="section-label reveal">// work experience</p>
				<h2 class="reveal reveal-delay-1">Experience</h2>
				<div class="timeline">

					<div class="timeline-item reveal reveal-delay-1">
						<div class="timeline-dot"></div>
						<div class="timeline-content">
							<div class="timeline-header">
								<div>
									<h3>Software Engineer Intern</h3>
									<p class="timeline-org">ST Advisory · Kota Kinabalu, Sabah</p>
								</div>
								<span class="timeline-date">Feb 2026 – Present</span>
							</div>
							<ul class="timeline-points">
								<li>Developing and maintaining web applications using Ruby on Rails, Ionic Angular, and Quasar Vue</li>
								<li>Building cross-platform mobile apps via Capacitor (PWA → native iOS/Android)</li>
								<li>Working with PostgreSQL and Docker in a real-world production environment</li>
								<li>Collaborating in a fast-paced boutique consulting team delivering AI, data analytics & IT solutions</li>
							</ul>
							<div class="timeline-tags">
								<span class="tag">Ruby on Rails</span>
								<span class="tag">Ionic Angular</span>
								<span class="tag">Quasar Vue</span>
								<span class="tag">Capacitor</span>
								<span class="tag">PostgreSQL</span>
								<span class="tag">Docker</span>
								<span class="tag">SCSS</span>
							</div>
						</div>
					</div>

				</div>
			</section>

			<!-- Education -->
			<section class="section">
				<p class="section-label reveal">// education</p>
				<h2 class="reveal reveal-delay-1">Academic Background</h2>
				<div class="timeline">

					<div class="timeline-item reveal reveal-delay-1">
						<div class="timeline-dot accent-dot"></div>
						<div class="timeline-content">
							<div class="timeline-header">
								<div>
									<h3>Bachelor of Computer Science (Software Engineering)</h3>
									<p class="timeline-org">Universiti Malaysia Sabah (UMS) · Kota Kinabalu</p>
								</div>
								<span class="timeline-date">2022 – Present</span>
							</div>
							<p class="timeline-desc">Final year student. Focused on software engineering fundamentals, database systems, mobile development, and capstone project (eKAFA PIUMS).</p>
							<div class="cgpa-row">
								<div class="cgpa-stat">
									<span class="cgpa-value">3.52</span>
									<span class="cgpa-label">Current CGPA</span>
								</div>
								<div class="cgpa-stat">
									<span class="cgpa-value">5×</span>
									<span class="cgpa-label">Dean's List (GPA ≥ 3.5)</span>
								</div>
								<div class="cgpa-stat">
									<span class="cgpa-value">3.67</span>
									<span class="cgpa-label">Best Semester GPA</span>
								</div>
							</div>
							<div class="timeline-tags">
								<span class="tag">Final Year</span>
								<span class="tag">Software Engineering</span>
								<span class="tag">FYP</span>
							</div>
						</div>
					</div>

					<div class="timeline-item reveal reveal-delay-2">
						<div class="timeline-dot accent-dot"></div>
						<div class="timeline-content">
							<div class="timeline-header">
								<div>
									<h3>Module III - (Computer Science)</h3>
									<p class="timeline-org">Labuan Matriculation College · Labuan</p>
								</div>
								<span class="timeline-date">2021 – 2022</span>
							</div>
							<p class="timeline-desc">Completed fast track to university within a year, building the groundwork for a degree in computer science.</p>
						</div>
					</div>

					<div class="timeline-item reveal reveal-delay-3">
						<div class="timeline-dot accent-dot"></div>
						<div class="timeline-content">
							<div class="timeline-header">
								<div>
									<h3>SPM (Secondary School Certificate)</h3>
									<p class="timeline-org">SM St John · Tuaran, Sabah</p>
								</div>
								<span class="timeline-date">2016 – 2020</span>
							</div>
							<p class="timeline-desc">Science Stream. PT3: 7A, 2B, 1C. SPM: 5A, 2B. Active in co-curricular activities, leadership, and community service.</p>
						</div>
					</div>

					<div class="timeline-item reveal reveal-delay-4">
						<div class="timeline-dot accent-dot"></div>
						<div class="timeline-content">
							<div class="timeline-header">
								<div>
									<h3>UPSR (Primary School)</h3>
									<p class="timeline-org">SK Tanjung Aru 1 → SK Laya-Laya · Tuaran, Sabah</p>
								</div>
								<span class="timeline-date">2010 – 2015</span>
							</div>
							<p class="timeline-desc">Started at SK Tanjung Aru 1 in Darjah 1, then transferred to SK Laya-Laya mid-Darjah 2. Completed primary school and sat for UPSR: 3A, 1B, 1C.</p>
						</div>
					</div>

				</div>
			</section>

			<!-- Leadership & Co-curricular -->
			<section class="section">
				<p class="section-label reveal">// leadership & activities</p>
				<h2 class="reveal reveal-delay-1">Leadership & Co-Curricular</h2>
				<div class="cards-grid">

					<div class="activity-card reveal reveal-delay-1">
						<div class="activity-icon">🪖</div>
						<div class="activity-content">
							<h3>Platoon Leader, Skuad 18</h3>
							<p class="activity-sub">KOR SUKSIS UMS</p>
							<p>Led a platoon in UMS's Police Volunteer Corps (SUKSIS). Awarded <strong>Best Trainer Overall from UMS</strong> at the 21st KOR SUKSIS Inspector Appointment & Graduation Parade Ceremony 2025 (at UTeM).</p>
						</div>
					</div>

					<div class="activity-card reveal reveal-delay-2">
						<div class="activity-icon">🕌</div>
						<div class="activity-content">
							<h3>Youth Development Exco</h3>
							<p class="activity-sub">Kelab Rakan Masjid UMS (KRM)</p>
							<p>Served on the executive committee responsible for youth development programs and community engagement initiatives under the UMS mosque club.</p>
						</div>
					</div>

					<div class="activity-card reveal reveal-delay-3">
						<div class="activity-icon">🤝</div>
						<div class="activity-content">
							<h3>External Relations Exco Secretariat</h3>
							<p class="activity-sub">PMFKI · UMS</p>
							<p>Handled external relations and secretariat duties for the Faculty of Computing & Informatics Student Association at UMS.</p>
						</div>
					</div>

					<div class="activity-card reveal reveal-delay-4">
						<div class="activity-icon">📋</div>
						<div class="activity-content">
							<h3>Team Leader — Sponsorship Unit</h3>
							<p class="activity-sub">FKI Pet Therapy Program</p>
							<p>Led the sponsorship unit for the FKI Pet Therapy Program, coordinating outreach and securing support for the event.</p>
						</div>
					</div>

					<div class="activity-card reveal reveal-delay-5">
						<div class="activity-icon">🏛️</div>
						<div class="activity-content">
							<h3>President, Sahabat Al-Irfaan</h3>
							<p class="activity-sub">Labuan Matriculation College</p>
							<p>Served as president of the Sahabat Al-Irfaan committee during foundation year, leading Islamic-oriented community activities.</p>
						</div>
					</div>

					<div class="activity-card reveal reveal-delay-1">
						<div class="activity-icon">📅</div>
						<div class="activity-content">
							<h3>Event Committee</h3>
							<p class="activity-sub">Into The Industry 3.0 · BaktiSuksis 2024</p>
							<p>Served on the organizing committees for Into The Industry 3.0 and BaktiSuksis 2024 — contributing to planning, coordination, and execution.</p>
						</div>
					</div>

				</div>
			</section>

			<!-- Workshops & Certifications -->
			<section class="section">
				<p class="section-label reveal">// workshops & training</p>
				<h2 class="reveal reveal-delay-1">Workshops & Training</h2>
				<div class="certs-list">

					<div class="cert-item reveal reveal-delay-1">
						<div class="cert-icon">💼</div>
						<div class="cert-content">
							<h3>Organizational Management Workshop</h3>
							<p class="cert-sub">Leadership & organizational skills training</p>
						</div>
						<span class="cert-badge">Workshop</span>
					</div>

					<div class="cert-item reveal reveal-delay-2">
						<div class="cert-icon">💻</div>
						<div class="cert-content">
							<h3>BeDigital Bootcamp (Miniseries)</h3>
							<p class="cert-sub">Petronas</p>
						</div>
						<span class="cert-badge">Bootcamp</span>
					</div>

					<div class="cert-item reveal reveal-delay-3">
						<div class="cert-icon">🚀</div>
						<div class="cert-content">
							<h3>Huawei-UMS Career Bootcamp</h3>
							<p class="cert-sub">Huawei × Universiti Malaysia Sabah</p>
						</div>
						<span class="cert-badge">Bootcamp</span>
					</div>

					<div class="cert-item reveal reveal-delay-4">
						<div class="cert-icon">🏢</div>
						<div class="cert-content">
							<h3>Protege Carnival @ KUSKOP</h3>
							<p class="cert-sub">Kementerian Usahawan dan Koperasi</p>
						</div>
						<span class="cert-badge">Carnival</span>
					</div>

					<div class="cert-item reveal reveal-delay-5">
						<div class="cert-icon">📈</div>
						<div class="cert-content">
							<h3>Understanding Stock Market 101 Seminar</h3>
							<p class="cert-sub">Financial literacy seminar</p>
						</div>
						<span class="cert-badge">Seminar</span>
					</div>

					<div class="cert-item reveal reveal-delay-1">
						<div class="cert-icon">🌐</div>
						<div class="cert-content">
							<h3>K-Youth Development Programme</h3>
							<p class="cert-sub">Kementerian Komunikasi · Digital skills & youth empowerment · In Progress</p>
						</div>
						<span class="cert-badge">Programme</span>
					</div>

					<div class="cert-item reveal reveal-delay-2">
						<div class="cert-icon">🤖</div>
						<div class="cert-content">
							<h3>AI Agents Engineering Programme</h3>
							<p class="cert-sub">Nexperts Academy · LLMs, Multi-Agent Systems, RAG & Production AI · 80 hrs · EC-Council & CompTIA · Upcoming</p>
						</div>
						<span class="cert-badge">Bootcamp</span>
					</div>

				</div>
			</section>

			<!-- Volunteering -->
			<section class="section">
				<p class="section-label reveal">// community</p>
				<h2 class="reveal reveal-delay-1">Volunteering</h2>
				<div class="timeline">

					<div class="timeline-item reveal reveal-delay-1">
						<div class="timeline-dot"></div>
						<div class="timeline-content">
							<div class="timeline-header">
								<div>
									<h3>Borneo International Marathon</h3>
									<p class="timeline-org">Volunteer · Kota Kinabalu, Sabah</p>
								</div>
								<span class="timeline-date">2024</span>
							</div>
							<p class="timeline-desc">Assisted in organizing and managing one of Borneo's biggest annual marathon events, supporting participants and coordinating on-ground logistics.</p>
						</div>
					</div>

					<div class="timeline-item reveal reveal-delay-2">
						<div class="timeline-dot"></div>
						<div class="timeline-content">
							<div class="timeline-header">
								<div>
									<h3>Blood Donation Campaign</h3>
									<p class="timeline-org">Volunteer · UMS</p>
								</div>
								<span class="timeline-date">2023</span>
							</div>
							<p class="timeline-desc">Volunteered at a blood donation drive on campus, helping with registration, donor coordination, and post-donation care.</p>
						</div>
					</div>

					<div class="timeline-item reveal reveal-delay-3">
						<div class="timeline-dot"></div>
						<div class="timeline-content">
							<div class="timeline-header">
								<div>
									<h3>Iftar Program</h3>
									<p class="timeline-org">Volunteer · Community</p>
								</div>
								<span class="timeline-date">2023</span>
							</div>
							<p class="timeline-desc">Participated in organizing a community Iftar program during Ramadan, preparing and distributing meals to the community.</p>
						</div>
					</div>

				</div>
			</section>

			<!-- Other Experience -->
			<section class="section">
				<p class="section-label reveal">// other experience</p>
				<h2 class="reveal reveal-delay-1">Part-Time & Side Work</h2>
				<div class="certs-list">

					<div class="cert-item reveal reveal-delay-1">
						<div class="cert-icon">🍽️</div>
						<div class="cert-content">
							<h3>Banquet & Events Crew</h3>
							<p class="cert-sub">Sabah International Convention Centre (SICC) · Kota Kinabalu</p>
						</div>
						<span class="cert-badge">Part-Time</span>
					</div>

					<div class="cert-item reveal reveal-delay-2">
						<div class="cert-icon">🛵</div>
						<div class="cert-content">
							<h3>Food Delivery Rider</h3>
							<p class="cert-sub">Self-employed · Kota Kinabalu</p>
						</div>
						<span class="cert-badge">Part-Time</span>
					</div>

					<div class="cert-item reveal reveal-delay-3">
						<div class="cert-icon">👕</div>
						<div class="cert-content">
							<h3>Jersey Reseller</h3>
							<p class="cert-sub">Self-employed · Online</p>
						</div>
						<span class="cert-badge">Side Business</span>
					</div>

					<div class="cert-item reveal reveal-delay-4">
						<div class="cert-icon">💼</div>
						<div class="cert-content">
							<h3>Freelance — Mobile App Tester</h3>
							<p class="cert-sub">Upwork · Remote · 2025 – Present</p>
						</div>
						<span class="cert-badge">Freelance</span>
					</div>

				</div>
			</section>

			<!-- What Next -->
			<section class="section whatnext-section">
				<p class="section-label reveal">// looking ahead</p>
				<h2 class="reveal reveal-delay-1">What's <span class="accent">Next?</span></h2>
				<p class="section-lead reveal reveal-delay-2">
					I'm finalizing my degree and actively planning my next move. Here's what I'm aiming for:
				</p>
				<div class="whatnext-grid">

					<div class="whatnext-card reveal reveal-delay-1">
						<div class="whatnext-number">01</div>
						<div class="whatnext-content">
							<h3>Graduate & Secure a Full-Time Role</h3>
							<p>Complete my Bachelor's in Software Engineering at UMS and transition into a full-time developer role — ideally in web, mobile, or full-stack development.</p>
						</div>
					</div>

					<div class="whatnext-card reveal reveal-delay-2">
						<div class="whatnext-number">02</div>
						<div class="whatnext-content">
							<h3>Ship More Products</h3>
							<p>Launch real products that solve real problems. I want to keep building things — whether as a freelancer, open-source contributor, or indie developer on the side.</p>
						</div>
					</div>

					<div class="whatnext-card reveal reveal-delay-3">
						<div class="whatnext-number">03</div>
						<div class="whatnext-content">
							<h3>Go Deeper Technically</h3>
							<p>Master the tools I've started: Rails, Docker, TypeScript, and cloud infrastructure. I want to go from "can use it" to "understands it deeply."</p>
						</div>
					</div>

					<div class="whatnext-card reveal reveal-delay-4">
						<div class="whatnext-number">04</div>
						<div class="whatnext-content">
							<h3>Give Back to Sabah</h3>
							<p>Long term, I want to help build tech solutions for Sabah — a place that shaped who I am. Whether through projects, education, or community, I want technology to reach here too.</p>
						</div>
					</div>

					<div class="whatnext-card reveal reveal-delay-5">
						<div class="whatnext-number">05</div>
						<div class="whatnext-content">
							<h3>Earn Professional Certifications</h3>
							<p>Build a portfolio of industry-recognised certifications — starting with AI engineering and cloud. Targeted certs include AWS, CompTIA, and EC-Council to back up hands-on experience with verified credentials.</p>
						</div>
					</div>

					<div class="whatnext-card reveal reveal-delay-1">
						<div class="whatnext-number">06</div>
						<div class="whatnext-content">
							<h3>Mentor & Share Knowledge</h3>
							<p>Give back to the next generation — whether through mentoring juniors at UMS, writing about what I've learned, or creating content online. If someone helped me grow, I want to do the same for others.</p>
						</div>
					</div>

				</div>

				<div class="whatnext-cta reveal reveal-delay-5">
					<p>Open to full-time roles, freelance projects, and good conversations.</p>
					<a href="/contact" class="btn btn-primary">Let's Talk →</a>
				</div>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 900px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 4em 1em;
	}

	.section {
		margin-bottom: 5em;
	}

	/* Hero */
	.page-hero {
		margin-bottom: 5em;
		padding-bottom: 3em;
		border-bottom: 1px solid var(--border);
	}

	.page-hero h1 {
		font-size: 2.8em;
		margin: 0.25em 0 0.5em;
	}

	.lead {
		font-size: 1.05em;
		color: var(--white-muted);
		line-height: 1.8;
		margin: 0 0 1.5em;
		max-width: 580px;
	}

	.hero-actions {
		display: flex;
		gap: 1em;
		flex-wrap: wrap;
	}

	/* Section headings */
	.section h2 {
		font-size: 1.8em;
		margin: 0.25em 0 1.25em;
	}

	.section-lead {
		font-size: 1em;
		color: var(--white-muted);
		line-height: 1.8;
		margin: 0 0 2em;
		max-width: 600px;
	}

	/* Timeline */
	.timeline {
		display: flex;
		flex-direction: column;
		gap: 0;
		border-left: 2px solid var(--border);
		margin-left: 10px;
	}

	.timeline-item {
		position: relative;
		padding: 0 0 2.5em 2em;
	}

	.timeline-item:last-child {
		padding-bottom: 0;
	}

	.timeline-dot {
		position: absolute;
		left: -9px;
		top: 4px;
		width: 16px;
		height: 16px;
		border-radius: 50%;
		background: var(--bg-secondary);
		border: 2px solid var(--border);
	}

	.accent-dot {
		border-color: var(--accent);
		background: var(--accent-glow);
	}

	.timeline-content {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 14px;
		padding: 1.5em;
		transition: border-color 0.2s;
	}

	.timeline-content:hover {
		border-color: var(--border-hover);
	}

	.timeline-header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1em;
		margin-bottom: 0.75em;
		flex-wrap: wrap;
	}

	.timeline-header h3 {
		font-size: 1.05em;
		margin: 0 0 0.2em;
		color: var(--white);
	}

	.timeline-org {
		font-size: 0.85em;
		color: var(--accent);
		margin: 0;
		font-family: var(--font-mono);
	}

	.timeline-date {
		font-family: var(--font-mono);
		font-size: 0.78em;
		color: var(--white-muted);
		white-space: nowrap;
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		padding: 0.25em 0.65em;
		border-radius: 100px;
		flex-shrink: 0;
	}

	.timeline-desc {
		font-size: 0.88em;
		color: var(--white-muted);
		line-height: 1.7;
		margin: 0 0 0.75em;
	}

	.timeline-points {
		font-size: 0.88em;
		color: var(--white-muted);
		line-height: 1.7;
		margin: 0 0 1em;
		padding-left: 1.25em;
	}

	.timeline-points li {
		margin-bottom: 0.35em;
	}

	.cgpa-row {
		display: flex;
		gap: 1.5em;
		margin: 0.75em 0;
		flex-wrap: wrap;
	}

	.cgpa-stat {
		display: flex;
		flex-direction: column;
		gap: 0.15em;
	}

	.cgpa-value {
		font-family: var(--font-mono);
		font-size: 1.4em;
		font-weight: 700;
		color: var(--accent);
	}

	.cgpa-label {
		font-size: 0.75em;
		color: var(--white-muted);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.timeline-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
	}

	/* Activity cards */
	.cards-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1em;
	}

	.activity-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 14px;
		padding: 1.5em;
		transition: border-color 0.2s, transform 0.2s;
	}

	.activity-card:hover {
		border-color: var(--border-hover);
		transform: translateY(-2px);
	}

	.activity-icon {
		font-size: 1.8em;
		margin-bottom: 0.75em;
	}

	.activity-content h3 {
		font-size: 1em;
		margin: 0 0 0.2em;
		color: var(--white);
	}

	.activity-sub {
		font-family: var(--font-mono);
		font-size: 0.75em;
		color: var(--accent);
		margin: 0 0 0.6em;
