		font-size: 0.72em;
		color: var(--accent);
		background: var(--accent-glow);
		border: 1px solid var(--border);
		padding: 0.2em 0.6em;
		border-radius: 100px;
	}

	.project-card h3 {
		font-size: 1.1em;
		margin: 0 0 0.5em;
		color: var(--white);
	}

	.project-card p {
		font-size: 0.88em;
		color: var(--white-muted);
		margin: 0 0 1em;
		line-height: 1.6;
	}

	.project-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
	}

	.projects-cta {
		text-align: center;
	}

	@media (max-width: 720px) {
		.currently-grid {
			grid-template-columns: 1fr;
		}

		.projects-grid {
			grid-template-columns: 1fr;
		}
	}

	/* Stack items clickable */
	.stack-item {
		cursor: pointer;
	}

	.stack-item:hover span {
		color: var(--accent);
	}

	/* Modal */
	.modal-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.7);
		backdrop-filter: blur(4px);
		z-index: 200;
		align-items: center;
		justify-content: center;
	}

	.modal-overlay.open {
		display: flex;
	}

	.modal {
		background: var(--bg-card);
		border: 1px solid var(--border-hover);
		border-radius: 16px;
		padding: 2em;
		max-width: 380px;
		width: calc(100% - 2em);
		position: relative;
		text-align: center;
		animation: modal-in 0.2s ease;
	}

	@keyframes modal-in {
		from { opacity: 0; transform: scale(0.95) translateY(10px); }
		to   { opacity: 1; transform: scale(1) translateY(0); }
	}

	.modal-close {
		position: absolute;
		top: 1em;
		right: 1em;
		background: none;
		border: none;
		color: var(--white-muted);
		font-size: 1em;
		cursor: pointer;
		transition: color 0.2s;
	}

	.modal-close:hover { color: var(--white); }

	.modal-icon {
		width: 56px;
		height: 56px;
		object-fit: contain;
		margin-bottom: 0.75em;
	}

	.modal-title {
		font-size: 1.2em;
		margin: 0 0 0.5em;
		color: var(--white);
	}

	.modal-desc {
		font-size: 0.9em;
		color: var(--white-muted);
		line-height: 1.7;
		margin: 0;
	}

	/* Scroll animations */
	.reveal {
		opacity: 0;
		transform: translateY(28px);
		transition: opacity 0.6s ease, transform 0.6s ease;
	}

	.reveal.visible {
		opacity: 1;
		transform: translateY(0);
	}

	.reveal-left {
		opacity: 0;
		transform: translateX(-32px);
		transition: opacity 0.7s ease, transform 0.7s ease;
	}

	.reveal-left.visible {
		opacity: 1;
		transform: translateX(0);
	}

	.reveal-right {
		opacity: 0;
		transform: translateX(32px);
		transition: opacity 0.7s ease, transform 0.7s ease;
	}

	.reveal-right.visible {
		opacity: 1;
		transform: translateX(0);
	}

	.reveal-delay-1 { transition-delay: 0.1s; }
	.reveal-delay-2 { transition-delay: 0.2s; }
	.reveal-delay-3 { transition-delay: 0.3s; }
	.reveal-delay-4 { transition-delay: 0.4s; }
	.reveal-delay-5 { transition-delay: 0.5s; }
	.reveal-delay-6 { transition-delay: 0.6s; }
</style>

<script>
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
				} else {
					entry.target.classList.remove('visible');
				}
			});
		},
		{ threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
	);

	document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach((el) => {
		observer.observe(el);
	});

	const skills: Record<string, string> = {
		'Java': 'A class-based, object-oriented programming language widely used for building enterprise applications, Android apps, and backend systems.',
		'C++': 'A powerful systems programming language that extends C with object-oriented features. Used for performance-critical applications and competitive programming.',
		'Python': 'A versatile, beginner-friendly language known for clean syntax. Popular in data science, automation, web development, and scripting.',
		'PHP': 'A server-side scripting language designed for web development. Powers a large portion of the web, including frameworks like Laravel and Yii2.',
		'JavaScript': 'The language of the web. Runs in browsers and on servers (via Node.js), enabling interactive and dynamic web experiences.',
		'TypeScript': 'A typed superset of JavaScript that catches errors at compile time. Makes large codebases easier to maintain and refactor.',
		'Kotlin': 'A modern, concise language for Android development. Fully interoperable with Java and officially recommended by Google for Android apps.',
		'Ruby': 'An elegant, developer-friendly language focused on simplicity and productivity. The language behind the Ruby on Rails framework.',
		'HTML': 'The standard markup language for creating web pages. Defines the structure and content of every website on the internet.',
		'CSS': 'The styling language for the web. Controls layout, colors, fonts, and animations to make web pages visually appealing.',
		'SCSS': 'A CSS preprocessor that adds variables, nesting, and mixins to CSS, making stylesheets more maintainable and powerful.',
		'Ruby on Rails': 'A full-stack web framework for Ruby that follows convention over configuration. Known for rapid development and clean code structure.',
		'Ionic Angular': 'A framework for building cross-platform mobile apps using web technologies (Angular + HTML/CSS). Write once, run on iOS, Android, and web.',
		'Quasar Vue': 'A Vue.js-based framework for building responsive SPAs, mobile apps, and desktop apps from a single codebase.',
		'Capacitor': 'A cross-platform native runtime that converts web apps (PWA) into native iOS and Android apps with access to device APIs.',
		'Yii2 MVC': 'A high-performance PHP framework following the MVC pattern. Used for building robust web applications quickly with built-in tools.',
		'Jetpack Compose': 'Android\'s modern UI toolkit for building native interfaces using declarative Kotlin code — less boilerplate, more intuitive.',
		'Astro': 'A modern static site framework focused on performance. Ships zero JavaScript by default and supports multiple UI frameworks.',
		'Docker': 'A platform for containerizing applications so they run consistently across any environment — development, testing, or production.',
		'Git': 'A distributed version control system for tracking code changes, collaborating with teams, and managing project history.',
		'GitHub': 'A cloud-based platform for hosting Git repositories. The standard for open-source collaboration and code sharing.',
		'MySQL': 'A popular open-source relational database. Widely used in web applications for storing and querying structured data.',
		'PostgreSQL': 'A powerful, open-source relational database known for reliability, advanced features, and standards compliance.',
		'Figma': 'A cloud-based design tool for UI/UX. Used for wireframing, prototyping, and collaborating on interface designs.',
		'Android Studio': 'The official IDE for Android development. Provides tools for building, testing, and debugging Android apps.',
	};

	const modal = document.getElementById('skillModal');
	const modalTitle = document.getElementById('modalTitle');
	const modalDesc = document.getElementById('modalDesc');
	const modalIcon = document.getElementById('modalIcon') as HTMLImageElement;
	const modalClose = document.getElementById('modalClose');

	document.querySelectorAll('.stack-item[data-skill]').forEach((el) => {
		el.addEventListener('click', () => {
			const name = (el as HTMLElement).dataset.skill!;
			const img = el.querySelector('img');
			if (modalTitle) modalTitle.textContent = name;
			if (modalDesc) modalDesc.textContent = skills[name] ?? 'A tool I use in my development workflow.';
			if (modalIcon && img) {
				modalIcon.src = img.src;
				modalIcon.alt = name;
				modalIcon.style.filter = img.style.filter ?? '';
			}
			modal?.classList.add('open');
		});
	});

	modalClose?.addEventListener('click', () => modal?.classList.remove('open'));
	modal?.addEventListener('click', (e) => { if (e.target === modal) modal.classList.remove('open'); });
	document.addEventListener('keydown', (e) => { if (e.key === 'Escape') modal?.classList.remove('open'); });
</script>
