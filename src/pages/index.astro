	}

	/* Tech stack */
	.techstack {
		margin-bottom: 5em;
	}

	.techstack h2 {
		font-size: 1.8em;
		margin-bottom: 1.25em;
	}

	.stack-groups {
		display: flex;
		flex-direction: column;
		gap: 1.25em;
	}

	.stack-group {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1.25em 1.5em;
	}

	.stack-label {
		font-family: var(--font-mono);
		font-size: 0.78em;
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin: 0 0 0.75em;
	}

	.stack-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
	}

	.stack-icons {
		display: flex;
		flex-wrap: wrap;
		gap: 1em;
		justify-content: center;
	}

	.stack-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.4em;
		width: 72px;
		text-align: center;
