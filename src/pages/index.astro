	/* Currently */
	.currently {
		margin-bottom: 5em;
	}

	.currently h2 {
		font-size: 1.8em;
		margin-bottom: 1.25em;
	}

	.currently-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1em;
	}

	.currently-card {
		display: flex;
		align-items: flex-start;
		gap: 1em;
		padding: 1.25em;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 12px;
	}

	.currently-icon {
