---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import profilePhoto from '../assets/GMBR.jpg';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-content">
					<p class="section-label reveal reveal-delay-1">// hello, world</p>
					<h1 class="reveal reveal-delay-2">
						Hi, I'm <span class="accent">Fadzyll</span>
					</h1>
					<p class="tagline reveal reveal-delay-3">Sabahan developer. Building technology with purpose.</p>
					<p class="bio reveal reveal-delay-4">
						I'm a software engineer who enjoys turning ideas into real, working products.
						Welcome to my personal space — where I document my journey, share my work, and grow in public.
					</p>
					<div class="cta-group reveal reveal-delay-5">
						<a href="/projects" class="btn btn-primary">View Projects</a>
						<a href="/contact" class="btn btn-outline">Get in Touch</a>
					</div>
					<div class="social-row reveal reveal-delay-6">
						<a href="https://github.com/Fadzyll" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
							<svg viewBox="0 0 16 16" width="22" height="22" aria-hidden="true">
								<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
							</svg>
							GitHub
						</a>
						<a href="https://www.linkedin.com/in/fadzilismail/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
							<svg viewBox="0 0 16 16" width="22" height="22" aria-hidden="true">
								<path fill="currentColor" d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/>
							</svg>
							LinkedIn
						</a>
					</div>
				</div>
				<div class="hero-avatar reveal-right">
					<div class="avatar-wrapper">
						<img src={profilePhoto.src} alt="Fadzyll" class="avatar-photo" />
						<div class="avatar-ring"></div>
					</div>
				</div>
			</section>

			</section>

			<section class="stats-row">
				<div class="stat-card reveal reveal-delay-1">
					<span class="stat-number accent">∞</span>
					<span class="stat-label">Curiosity</span>
				</div>
				<div class="stat-card reveal reveal-delay-2">
					<span class="stat-number accent">100%</span>
					<span class="stat-label">Purpose-driven</span>
				</div>
				<div class="stat-card reveal reveal-delay-3">
					<span class="stat-number accent">Sabah</span>
					<span class="stat-label">Based in</span>
				</div>
				<div class="stat-card reveal reveal-delay-4">
					<span class="stat-number accent">Open</span>
					<span class="stat-label">To opportunities</span>
				</div>
			</section>

			</section>

			<section class="currently">
				<p class="section-label reveal">// status update</p>
				<h2 class="reveal reveal-delay-1">Currently</h2>
				<div class="currently-grid">
					<div class="currently-card reveal reveal-delay-1">
						<span class="currently-icon">🎓</span>
						<div>
							<p class="currently-label">Studying</p>
							<p class="currently-value">BCompSc. Software Engineering at UMS · Final Year</p>
						</div>
					</div>
					<div class="currently-card reveal reveal-delay-2">
						<span class="currently-icon">💼</span>
						<div>
							<p class="currently-label">Interning At</p>
							<p class="currently-value">ST Advisory — a boutique consulting firm in AI, data analytics & IT solutions · Kota Kinabalu, Sabah</p>
						</div>
					</div>
					<div class="currently-card reveal reveal-delay-3">
						<span class="currently-icon">🛠️</span>
						<div>
							<p class="currently-label">Building</p>
							<p class="currently-value">eKAFA PIUMS — a web-based school management system (FYP)</p>
						</div>
					</div>
					<div class="currently-card reveal reveal-delay-4">
						<span class="currently-icon">📖</span>
						<div>
							<p class="currently-label">Learning</p>
							<p class="currently-value">Ruby on Rails, Ionic Angular, Quasar Vue & Docker on the job</p>
						</div>
					</div>
				</div>
			</section>

			</section>

			<section class="techstack">
				<p class="section-label reveal">// tools of the trade</p>
				<h2 class="reveal reveal-delay-1">Tech Stack</h2>
				<div class="stack-groups">
					<div class="stack-group reveal reveal-delay-1">
						<p class="stack-label">Languages</p>
						<div class="stack-icons">
							<div class="stack-item" data-skill="Java">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/java/java-original.svg" alt="Java" />
								<span>Java</span>
							</div>
							<div class="stack-item" data-skill="C++">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/cplusplus/cplusplus-original.svg" alt="C++" />
								<span>C++</span>
							</div>
							<div class="stack-item" data-skill="Python">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg" alt="Python" />
								<span>Python</span>
							</div>
							<div class="stack-item" data-skill="PHP">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/php/php-original.svg" alt="PHP" />
								<span>PHP</span>
							</div>
							<div class="stack-item" data-skill="JavaScript">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg" alt="JavaScript" />
								<span>JavaScript</span>
							</div>
							<div class="stack-item" data-skill="TypeScript">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg" alt="TypeScript" />
								<span>TypeScript</span>
							</div>
							<div class="stack-item" data-skill="Kotlin">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/kotlin/kotlin-original.svg" alt="Kotlin" />
								<span>Kotlin</span>
							</div>
							<div class="stack-item" data-skill="Ruby">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/ruby/ruby-original.svg" alt="Ruby" />
								<span>Ruby</span>
							</div>
							<div class="stack-item" data-skill="HTML">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg" alt="HTML" />
								<span>HTML</span>
							</div>
							<div class="stack-item" data-skill="CSS">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg" alt="CSS" />
								<span>CSS</span>
							</div>
							<div class="stack-item" data-skill="SCSS">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/sass/sass-original.svg" alt="SCSS" />
								<span>SCSS</span>
							</div>
						</div>
					</div>
					<div class="stack-group reveal reveal-delay-2">
						<p class="stack-label">Frameworks & Tools</p>
						<div class="stack-icons">
							<div class="stack-item" data-skill="Ruby on Rails">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/rails/rails-plain.svg" alt="Ruby on Rails" />
								<span>Rails</span>
							</div>
							<div class="stack-item" data-skill="Ionic Angular">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/ionic/ionic-original.svg" alt="Ionic" />
								<span>Ionic</span>
							</div>
							<div class="stack-item" data-skill="Quasar Vue">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/vuejs/vuejs-original.svg" alt="Vue" />
								<span>Quasar Vue</span>
							</div>
							<div class="stack-item" data-skill="Capacitor">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/capacitor/capacitor-original.svg" alt="Capacitor" />
								<span>Capacitor</span>
							</div>
							<div class="stack-item" data-skill="Yii2 MVC">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/yii/yii-original.svg" alt="Yii2" />
								<span>Yii2 MVC</span>
							</div>
							<div class="stack-item" data-skill="Jetpack Compose">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/android/android-original.svg" alt="Jetpack Compose" />
								<span>Jetpack Compose</span>
							</div>
							<div class="stack-item" data-skill="Docker">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg" alt="Docker" />
								<span>Docker</span>
							</div>
							<div class="stack-item" data-skill="Astro">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-original.svg" alt="Astro" />
								<span>Astro</span>
							</div>
							<div class="stack-item" data-skill="Git">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg" alt="Git" />
								<span>Git</span>
							</div>
							<div class="stack-item" data-skill="GitHub">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg" alt="GitHub" style="filter: invert(1) brightness(0.8);" />
								<span>GitHub</span>
							</div>
							<div class="stack-item" data-skill="Figma">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/figma/figma-original.svg" alt="Figma" />
								<span>Figma</span>
							</div>
							<div class="stack-item" data-skill="Android Studio">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/androidstudio/androidstudio-original.svg" alt="Android Studio" />
								<span>Android Studio</span>
							</div>
							<div class="stack-item" data-skill="MySQL">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg" alt="MySQL" />
								<span>MySQL</span>
							</div>
							<div class="stack-item" data-skill="PostgreSQL">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg" alt="PostgreSQL" />
								<span>PostgreSQL</span>
							</div>
						</div>
					</div>
					<div class="stack-group reveal reveal-delay-3">
						<p class="stack-label">Concepts</p>
						<div class="stack-icons">
							<div class="stack-item concept">
								<span class="concept-icon">⚙️</span>
								<span>OOP</span>
							</div>
							<div class="stack-item concept">
								<span class="concept-icon">🔄</span>
								<span>SDLC</span>
							</div>
							<div class="stack-item concept">
								<span class="concept-icon">🏗️</span>
								<span>System Design</span>
							</div>
							<div class="stack-item concept">
								<span class="concept-icon">🧮</span>
								<span>DSA</span>
							</div>
							<div class="stack-item concept">
								<span class="concept-icon">🧱</span>
								<span>MVVM</span>
							</div>
							<div class="stack-item concept">
								<span class="concept-icon">🗄️</span>
								<span>Database Design</span>
							</div>
						</div>
					</div>
				</div>
			</section>

			</section>

			<section class="featured-projects">
				<p class="section-label reveal">// what i've built</p>
				<h2 class="reveal reveal-delay-1">Featured Projects</h2>
				<div class="projects-grid">
					<div class="project-card reveal reveal-delay-2">
						<div class="project-header">
							<span class="project-icon">🌐</span>
							<span class="project-status">FYP · In Progress</span>
						</div>
						<h3>eKAFA PIUMS</h3>
						<p>A web-based school management system to digitize and streamline KAFA workload management — replacing traditional paper-based processes.</p>
						<div class="project-tags">
							<span class="tag">PHP</span>
							<span class="tag">Yii2 MVC</span>
							<span class="tag">JavaScript</span>
							<span class="tag">MySQL</span>
							<span class="tag">Git</span>
						</div>
					</div>
					<div class="project-card reveal reveal-delay-3">
						<div class="project-header">
							<span class="project-icon">📱</span>
							<span class="project-status">Completed · Jul 2025</span>
						</div>
						<h3>Kindergarten Management App</h3>
						<p>A mobile app for kindergarten settings — allows teachers to manage student data, attendance, class assignments, and payments efficiently.</p>
						<div class="project-tags">
							<span class="tag">Kotlin</span>
							<span class="tag">Jetpack Compose</span>
							<span class="tag">Room DB</span>
							<span class="tag">MVVM</span>
						</div>
					</div>
				</div>
				<div class="projects-cta reveal reveal-delay-4">
					<a href="/projects" class="btn btn-outline">View all projects →</a>
				</div>
			</section>

			</section>

			<section class="quick-links">
				<p class="section-label reveal">// explore</p>
				<h2 class="reveal reveal-delay-1">What's here</h2>
				<div class="links-grid">
					<a href="/about" class="link-card reveal reveal-delay-1">
						<span class="link-icon">👤</span>
						<div>
							<h3>About Me</h3>
							<p>Who I am, where I'm from, and what drives me — including my blog.</p>
						</div>
						<span class="link-arrow">→</span>
					</a>
					<a href="/projects" class="link-card reveal reveal-delay-2">
						<span class="link-icon">🛠️</span>
						<div>
							<h3>Projects & Skills</h3>
							<p>Things I've built and the technologies I work with.</p>
						</div>
						<span class="link-arrow">→</span>
					</a>
					<a href="/career" class="link-card reveal reveal-delay-3">
						<span class="link-icon">🚀</span>
						<div>
							<h3>Career</h3>
							<p>Work experience, academic history, achievements, and what's next.</p>
						</div>
						<span class="link-arrow">→</span>
					</a>
					<a href="/contact" class="link-card reveal reveal-delay-4">
						<span class="link-icon">✉️</span>
						<div>
							<h3>Contact</h3>
							<p>Reach out — always open to a good conversation.</p>
						</div>
						<span class="link-arrow">→</span>
					</a>
				</div>
			</section>
			</section>
		</main>
		<Footer />

		<!-- Skill popup modal -->
		<div class="modal-overlay" id="skillModal">
			<div class="modal">
				<button class="modal-close" id="modalClose">✕</button>
				<img class="modal-icon" id="modalIcon" src="" alt="" />
				<h3 class="modal-title" id="modalTitle"></h3>
				<p class="modal-desc" id="modalDesc"></p>
			</div>
		</div>
	</body>
</html>

<style>

	/* Hero */
	.hero {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 3em;
		min-height: calc(100vh - 64px);
		padding: 4em 0 3em;
	}

	.hero-content {
		flex: 1;
		max-width: 580px;
	}

	.hero-content h1 {
		font-size: 3.5em;
		line-height: 1.1;
		margin: 0.25em 0 0.4em;
	}

	.tagline {
		font-size: 1.2em;
		color: var(--white);
		font-weight: 500;
		margin: 0 0 1em;
	}

	.bio {
		font-size: 1em;
		color: var(--white-muted);
		line-height: 1.8;
		margin-bottom: 2em;
		max-width: 480px;
	}

	.cta-group {
		display: flex;
		gap: 1em;
		flex-wrap: wrap;
		margin-bottom: 2em;
	}

	.social-row {
		display: flex;
		gap: 1.5em;
		align-items: center;
	}

	.social-row a {
		display: inline-flex;
		align-items: center;
		gap: 0.5em;
		color: var(--white-muted);
		font-size: 0.9em;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.social-row a:hover {
		color: var(--accent);
	}

	/* Avatar */
	.hero-avatar {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.avatar-wrapper {
		position: relative;
		width: 280px;
		height: 280px;
	}

	.avatar-photo {
		width: 264px;
		height: 264px;
		border-radius: 50%;
		object-fit: cover;
		object-position: center top;
		border: 2px solid var(--border);
		position: relative;
		z-index: 1;
		margin: 8px;
		display: block;
	}

	.avatar-ring {
		position: absolute;
		inset: 0;
		border-radius: 50%;
		border: 2px solid var(--accent);
		opacity: 0.3;
		animation: pulse-ring 3s ease-in-out infinite;
	}

	@keyframes pulse-ring {
		0%, 100% { transform: scale(1); opacity: 0.3; }
		50% { transform: scale(1.05); opacity: 0.1; }
	}

	/* Stats */
	.stats-row {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 1em;
		margin-bottom: 5em;
	}

	.stat-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1.25em 1em;
		text-align: center;
		display: flex;
		flex-direction: column;
		gap: 0.25em;
	}

	.stat-number {
		font-size: 1.4em;
		font-weight: 700;
		font-family: var(--font-mono);
	}

	.stat-label {
		font-size: 0.8em;
		color: var(--white-muted);
	}

	/* Quick links */
	.quick-links {
		margin-bottom: 5em;
	}

	.quick-links h2 {
		font-size: 1.8em;
		margin-bottom: 1.25em;
	}

	.links-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1em;
	}

	.link-card {
		display: flex;
		align-items: flex-start;
		gap: 1em;
		padding: 1.25em;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 12px;
		text-decoration: none;
		color: inherit;
		transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
	}

	.link-card:hover {
		border-color: var(--border-hover);
		transform: translateY(-2px);
		box-shadow: var(--box-shadow-hover);
		color: inherit;
	}

	.link-icon {
		font-size: 1.4em;
		flex-shrink: 0;
		margin-top: 0.1em;
	}

	.link-card h3 {
		font-size: 1em;
		margin: 0 0 0.25em;
		color: var(--white);
	}

	.link-card p {
		font-size: 0.82em;
		color: var(--white-muted);
		margin: 0;
		line-height: 1.5;
	}

	.link-arrow {
		margin-left: auto;
		color: var(--accent);
		font-size: 1.1em;
		flex-shrink: 0;
		opacity: 0;
		transition: opacity 0.2s ease, transform 0.2s ease;
	}

	.link-card:hover .link-arrow {
		opacity: 1;
		transform: translateX(3px);
	}

	@media (max-width: 900px) {
		.hero {
			flex-direction: column-reverse;
			align-items: center;
			min-height: auto;
			padding: 3em 0 2em;
			text-align: center;
		}

		.hero-content {
			max-width: 100%;
			display: flex;
			flex-direction: column;
			align-items: center;
			text-align: center;
		}

		.hero-content h1 {
			font-size: 2.5em;
		}

		.hero-content p {
			text-align: center !important;
		}

