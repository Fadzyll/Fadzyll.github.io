---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Projects — Fadzyll" description="Software projects I've built — from web apps to mobile apps, with the tools and technologies behind them." />
	</head>
	<body>
		<Header />
		<main>

			<!-- Hero -->
			<section class="page-hero">
				<p class="section-label reveal">// what i've built</p>
				<h1 class="reveal reveal-delay-1">Projects & <span class="accent">Skills</span></h1>
				<p class="lead reveal reveal-delay-2">A collection of things I've built — from final year projects to personal experiments. Each one taught me something new.</p>
			</section>

			<!-- Projects -->
			<section class="section">
				<p class="section-label reveal">// projects</p>
				<h2 class="reveal reveal-delay-1">What I've Built</h2>
				<div class="projects-list">

					<div class="project-card reveal reveal-delay-1">
						<div class="project-image">
							<div class="project-image-placeholder">
								<span>🌐</span>
								<p>Screenshot coming soon</p>
							</div>
						</div>
						<div class="project-info">
							<div class="project-meta">
								<span class="project-badge">Final Year Project</span>
								<span class="project-status active">● In Progress</span>
							</div>
							<h3>eKAFA PIUMS</h3>
							<p class="project-date">Feb 2025 — Present</p>
							<p class="project-desc">A web-based school management system built to replace traditional paper-based processes for managing KAFA workload. The system digitizes day-to-day operations, making it easier for administrators and teachers to manage tasks efficiently.</p>
							<div class="project-highlights">
								<span class="highlight-item">📋 Digitizes KAFA workload management</span>
								<span class="highlight-item">🔐 Role-based access control</span>
								<span class="highlight-item">📊 Admin dashboard & reporting</span>
							</div>
							<div class="project-tags">
								<span class="tag">PHP</span>
								<span class="tag">Yii2 MVC</span>
								<span class="tag">JavaScript</span>
								<span class="tag">MySQL</span>
								<span class="tag">CSS</span>
								<span class="tag">Git</span>
								<span class="tag">Laragon</span>
							</div>
						</div>
					</div>

					<div class="project-card reveal reveal-delay-2">
						<div class="project-image">
							<div class="project-image-placeholder">
								<span>📱</span>
								<p>Screenshot coming soon</p>
							</div>
						</div>
						<div class="project-info">
							<div class="project-meta">
								<span class="project-badge">Mobile App</span>
								<span class="project-status done">✓ Completed</span>
							</div>
							<h3>Kindergarten Management App</h3>
							<p class="project-date">March 2025 — July 2025</p>
							<p class="project-desc">A mobile application designed for kindergarten settings, allowing teachers to efficiently manage student data, attendance, class assignments, and payment records — all in one place.</p>
							<div class="project-highlights">
								<span class="highlight-item">👶 Student data management</span>
								<span class="highlight-item">📅 Attendance tracking</span>
								<span class="highlight-item">💳 Payment records</span>
							</div>
							<div class="project-tags">
								<span class="tag">Kotlin</span>
								<span class="tag">Jetpack Compose</span>
								<span class="tag">Room Database</span>
								<span class="tag">MVVM</span>
								<span class="tag">Material 3</span>
							</div>
						</div>
					</div>

				</div>
			</section>

			<!-- Skills -->
			<section class="section">
				<p class="section-label reveal">// skills</p>
				<h2 class="reveal reveal-delay-1">Technical Skills</h2>
				<div class="skills-grid">

					<div class="skill-group reveal reveal-delay-1">
						<h3 class="skill-group-title">
							<span class="skill-group-icon">💬</span> Languages
						</h3>
						<div class="skill-list">
							<div class="skill-item" data-skill="Java">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/java/java-original.svg" alt="Java" />
								<span>Java</span>
							</div>
							<div class="skill-item" data-skill="C++">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/cplusplus/cplusplus-original.svg" alt="C++" />
								<span>C++</span>
							</div>
							<div class="skill-item" data-skill="Python">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg" alt="Python" />
								<span>Python</span>
							</div>
							<div class="skill-item" data-skill="PHP">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/php/php-original.svg" alt="PHP" />
								<span>PHP</span>
							</div>
							<div class="skill-item" data-skill="JavaScript">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg" alt="JavaScript" />
								<span>JavaScript</span>
							</div>
							<div class="skill-item" data-skill="TypeScript">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg" alt="TypeScript" />
								<span>TypeScript</span>
							</div>
							<div class="skill-item" data-skill="Kotlin">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/kotlin/kotlin-original.svg" alt="Kotlin" />
								<span>Kotlin</span>
							</div>
							<div class="skill-item" data-skill="Ruby">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/ruby/ruby-original.svg" alt="Ruby" />
								<span>Ruby</span>
							</div>
							<div class="skill-item" data-skill="HTML">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg" alt="HTML" />
								<span>HTML</span>
							</div>
							<div class="skill-item" data-skill="CSS">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg" alt="CSS" />
								<span>CSS</span>
							</div>
							<div class="skill-item" data-skill="SCSS">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/sass/sass-original.svg" alt="SCSS" />
								<span>SCSS</span>
							</div>
						</div>
					</div>

					<div class="skill-group reveal reveal-delay-2">
						<h3 class="skill-group-title">
							<span class="skill-group-icon">🛠️</span> Frameworks & Tools
						</h3>
						<div class="skill-list">
							<div class="skill-item" data-skill="Ruby on Rails">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/rails/rails-plain.svg" alt="Rails" />
								<span>Ruby on Rails</span>
							</div>
							<div class="skill-item" data-skill="Ionic Angular">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/ionic/ionic-original.svg" alt="Ionic" />
								<span>Ionic Angular</span>
							</div>
							<div class="skill-item" data-skill="Quasar Vue">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/vuejs/vuejs-original.svg" alt="Vue" />
								<span>Quasar Vue</span>
							</div>
							<div class="skill-item" data-skill="Capacitor">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/capacitor/capacitor-original.svg" alt="Capacitor" />
								<span>Capacitor</span>
							</div>
							<div class="skill-item" data-skill="Yii2 MVC">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/yii/yii-original.svg" alt="Yii2" />
								<span>Yii2 MVC</span>
							</div>
							<div class="skill-item" data-skill="Jetpack Compose">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/android/android-original.svg" alt="Jetpack Compose" />
								<span>Jetpack Compose</span>
							</div>
							<div class="skill-item" data-skill="Astro">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/astro/astro-original.svg" alt="Astro" />
								<span>Astro</span>
							</div>
							<div class="skill-item" data-skill="Docker">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg" alt="Docker" />
								<span>Docker</span>
							</div>
							<div class="skill-item" data-skill="Git">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg" alt="Git" />
								<span>Git</span>
							</div>
							<div class="skill-item" data-skill="GitHub">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg" alt="GitHub" style="filter: invert(1) brightness(0.8);" />
								<span>GitHub</span>
							</div>
							<div class="skill-item" data-skill="MySQL">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/mysql/mysql-original.svg" alt="MySQL" />
								<span>MySQL</span>
							</div>
							<div class="skill-item" data-skill="PostgreSQL">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/postgresql/postgresql-original.svg" alt="PostgreSQL" />
								<span>PostgreSQL</span>
							</div>
							<div class="skill-item" data-skill="Figma">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/figma/figma-original.svg" alt="Figma" />
								<span>Figma</span>
							</div>
							<div class="skill-item" data-skill="Android Studio">
								<img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/androidstudio/androidstudio-original.svg" alt="Android Studio" />
								<span>Android Studio</span>
							</div>
						</div>
					</div>

					<div class="skill-group reveal reveal-delay-3">
						<h3 class="skill-group-title">
							<span class="skill-group-icon">🧠</span> Concepts
						</h3>
						<div class="concepts-tags">
							<span class="tag">OOP</span>
							<span class="tag">SDLC</span>
							<span class="tag">System Design</span>
							<span class="tag">Data Structures & Algorithms</span>
							<span class="tag">MVVM</span>
							<span class="tag">MVC</span>
							<span class="tag">Database Design</span>
							<span class="tag">ERD</span>
							<span class="tag">System Analysis</span>
							<span class="tag">Data Modelling</span>
							<span class="tag">Version Control</span>
							<span class="tag">Agile</span>
						</div>
					</div>

				</div>
			</section>

		</main>

		<!-- Skill popup modal -->
		<div class="modal-overlay" id="skillModal">
			<div class="modal">
				<button class="modal-close" id="modalClose">✕</button>
				<img class="modal-icon" id="modalIcon" src="" alt="" />
				<h3 class="modal-title" id="modalTitle"></h3>
				<p class="modal-desc" id="modalDesc"></p>
			</div>
		</div>

		<Footer />
	</body>
</html>

<style>
	main {
		width: 900px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 4em 1em;
	}

	.section {
		margin-bottom: 5em;
	}

	.section h2 {
		font-size: 1.8em;
		margin-bottom: 1.25em;
	}

	/* Hero */
	.page-hero {
		margin-bottom: 4em;
		padding-bottom: 3em;
		border-bottom: 1px solid var(--border);
	}

	.page-hero h1 {
		font-size: 2.8em;
		margin: 0.25em 0 0.5em;
	}

	.lead {
		font-size: 1.05em;
		color: var(--white-muted);
		line-height: 1.8;
		margin: 0;
		max-width: 600px;
	}

	/* Projects */
	.projects-list {
		display: flex;
		flex-direction: column;
		gap: 2em;
	}

	.project-card {
		display: grid;
		grid-template-columns: 320px 1fr;
		gap: 2em;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 16px;
		overflow: hidden;
		transition: border-color 0.2s, transform 0.2s;
	}

	.project-card:hover {
		border-color: var(--border-hover);
		transform: translateY(-2px);
	}

	.project-image {
		background: var(--bg-secondary);
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 220px;
	}

	.project-image-placeholder {
		text-align: center;
		padding: 2em;
	}

	.project-image-placeholder span {
		font-size: 3em;
		display: block;
		margin-bottom: 0.5em;
	}

	.project-image-placeholder p {
		font-size: 0.8em;
		color: var(--white-muted);
		margin: 0;
		opacity: 0.5;
	}

	.project-info {
		padding: 1.75em 1.75em 1.75em 0;
		display: flex;
		flex-direction: column;
		gap: 0.75em;
	}

	.project-meta {
		display: flex;
		align-items: center;
		gap: 0.75em;
	}

	.project-badge {
		font-family: var(--font-mono);
		font-size: 0.72em;
		color: var(--accent);
		background: var(--accent-glow);
		border: 1px solid var(--border);
		padding: 0.2em 0.75em;
		border-radius: 100px;
	}

	.project-status {
		font-family: var(--font-mono);
		font-size: 0.72em;
		padding: 0.2em 0.75em;
		border-radius: 100px;
	}

	.project-status.active {
		color: #4ade80;
		background: rgba(74, 222, 128, 0.1);
		border: 1px solid rgba(74, 222, 128, 0.2);
	}

	.project-status.done {
		color: var(--white-muted);
		background: rgba(168, 184, 208, 0.1);
		border: 1px solid rgba(168, 184, 208, 0.2);
	}

	.project-info h3 {
		font-size: 1.3em;
		margin: 0;
		color: var(--white);
	}

	.project-date {
		font-family: var(--font-mono);
		font-size: 0.78em;
		color: var(--white-muted);
		margin: 0;
	}

	.project-desc {
		font-size: 0.9em;
		color: var(--white-muted);
		margin: 0;
		line-height: 1.7;
	}

	.project-highlights {
		display: flex;
		flex-direction: column;
		gap: 0.3em;
	}

	.highlight-item {
		font-size: 0.83em;
		color: var(--white-muted);
	}

	.project-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
		margin-top: 0.25em;
	}

	/* Skills */
	.skills-grid {
		display: flex;
		flex-direction: column;
		gap: 1.5em;
	}

	.skill-group {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 1.5em;
	}

	.skill-group-title {
		font-size: 1em;
		margin: 0 0 1.25em;
		color: var(--white);
		display: flex;
		align-items: center;
		gap: 0.5em;
	}

	.skill-group-icon {
		font-size: 1.1em;
	}

	.skill-list {
		display: flex;
		flex-wrap: wrap;
		gap: 1.25em;
		justify-content: center;
	}

	.skill-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.4em;
		width: 72px;
		text-align: center;
	}

	.skill-item img {
		width: 38px;
		height: 38px;
		object-fit: contain;
		transition: transform 0.2s ease;
	}

	.skill-item:hover img {
		transform: translateY(-3px);
	}

	.skill-item span {
		font-size: 0.7em;
		color: var(--white-muted);
		line-height: 1.2;
	}

	.concepts-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em;
	}

	/* Skill items clickable */
	.skill-item {
		cursor: pointer;
	}

	.skill-item:hover span {
		color: var(--accent);
	}

	/* Modal */
	.modal-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.7);
		backdrop-filter: blur(4px);
		z-index: 200;
		align-items: center;
		justify-content: center;
	}

	.modal-overlay.open {
		display: flex;
	}

	.modal {
		background: var(--bg-card);
		border: 1px solid var(--border-hover);
		border-radius: 16px;
		padding: 2em;
		max-width: 380px;
		width: calc(100% - 2em);
		position: relative;
		text-align: center;
		animation: modal-in 0.2s ease;
	}

	@keyframes modal-in {
		from { opacity: 0; transform: scale(0.95) translateY(10px); }
		to   { opacity: 1; transform: scale(1) translateY(0); }
	}

	.modal-close {
		position: absolute;
		top: 1em;
		right: 1em;
		background: none;
		border: none;
		color: var(--white-muted);
		font-size: 1em;
		cursor: pointer;
		transition: color 0.2s;
	}

	.modal-close:hover {
		color: var(--white);
	}

	.modal-icon {
		width: 56px;
		height: 56px;
		object-fit: contain;
		margin-bottom: 0.75em;
	}

	.modal-title {
		font-size: 1.2em;
		margin: 0 0 0.5em;
		color: var(--white);
	}

	.modal-desc {
		font-size: 0.9em;
		color: var(--white-muted);
		line-height: 1.7;
		margin: 0;
	}

	/* Scroll animations */
	.reveal {
		opacity: 0;
		transform: translateY(28px);
		transition: opacity 0.6s ease, transform 0.6s ease;
	}

	.reveal.visible {
		opacity: 1;
		transform: translateY(0);
	}

	.reveal-delay-1 { transition-delay: 0.1s; }
	.reveal-delay-2 { transition-delay: 0.2s; }
	.reveal-delay-3 { transition-delay: 0.3s; }

	@media (max-width: 720px) {
		.project-card {
			grid-template-columns: 1fr;
		}

		.project-info {
			padding: 1.25em;
		}

		.project-image {
			min-height: 160px;
		}

		.page-hero h1 {
			font-size: 2em;
		}
	}
</style>

<script>
	const skills: Record<string, string> = {
		'Java': 'A class-based, object-oriented programming language widely used for building enterprise applications, Android apps, and backend systems.',
		'C++': 'A powerful systems programming language that extends C with object-oriented features. Used for performance-critical applications and competitive programming.',
		'Python': 'A versatile, beginner-friendly language known for clean syntax. Popular in data science, automation, web development, and scripting.',
		'PHP': 'A server-side scripting language designed for web development. Powers a large portion of the web, including frameworks like Laravel and Yii2.',
		'JavaScript': 'The language of the web. Runs in browsers and on servers (via Node.js), enabling interactive and dynamic web experiences.',
		'TypeScript': 'A typed superset of JavaScript that catches errors at compile time. Makes large codebases easier to maintain and refactor.',
		'Kotlin': 'A modern, concise language for Android development. Fully interoperable with Java and officially recommended by Google for Android apps.',
		'Ruby': 'An elegant, developer-friendly language focused on simplicity and productivity. The language behind the Ruby on Rails framework.',
		'HTML': 'The standard markup language for creating web pages. Defines the structure and content of every website on the internet.',
		'CSS': 'The styling language for the web. Controls layout, colors, fonts, and animations to make web pages visually appealing.',
		'SCSS': 'A CSS preprocessor that adds variables, nesting, and mixins to CSS, making stylesheets more maintainable and powerful.',
		'Ruby on Rails': 'A full-stack web framework for Ruby that follows convention over configuration. Known for rapid development and clean code structure.',
		'Ionic Angular': 'A framework for building cross-platform mobile apps using web technologies (Angular + HTML/CSS). Write once, run on iOS, Android, and web.',
		'Quasar Vue': 'A Vue.js-based framework for building responsive SPAs, mobile apps, and desktop apps from a single codebase.',
		'Capacitor': 'A cross-platform native runtime that converts web apps (PWA) into native iOS and Android apps with access to device APIs.',
		'Yii2 MVC': 'A high-performance PHP framework following the MVC pattern. Used for building robust web applications quickly with built-in tools.',
		'Jetpack Compose': 'Android\'s modern UI toolkit for building native interfaces using declarative Kotlin code — less boilerplate, more intuitive.',
		'Astro': 'A modern static site framework focused on performance. Ships zero JavaScript by default and supports multiple UI frameworks.',
		'Docker': 'A platform for containerizing applications so they run consistently across any environment — development, testing, or production.',
		'Git': 'A distributed version control system for tracking code changes, collaborating with teams, and managing project history.',
		'GitHub': 'A cloud-based platform for hosting Git repositories. The standard for open-source collaboration and code sharing.',
		'MySQL': 'A popular open-source relational database. Widely used in web applications for storing and querying structured data.',
		'PostgreSQL': 'A powerful, open-source relational database known for reliability, advanced features, and standards compliance.',
		'Figma': 'A cloud-based design tool for UI/UX. Used for wireframing, prototyping, and collaborating on interface designs.',
		'Android Studio': 'The official IDE for Android development. Provides tools for building, testing, and debugging Android apps.',
	};

	const modal = document.getElementById('skillModal');
	const modalTitle = document.getElementById('modalTitle');
	const modalDesc = document.getElementById('modalDesc');
	const modalIcon = document.getElementById('modalIcon') as HTMLImageElement;
	const modalClose = document.getElementById('modalClose');

	document.querySelectorAll('.skill-item[data-skill]').forEach((el) => {
		el.addEventListener('click', () => {
			const name = (el as HTMLElement).dataset.skill!;
			const img = el.querySelector('img');
			if (modalTitle) modalTitle.textContent = name;
			if (modalDesc) modalDesc.textContent = skills[name] ?? 'A tool I use in my development workflow.';
			if (modalIcon && img) {
				modalIcon.src = img.src;
				modalIcon.alt = name;
				modalIcon.style.filter = img.style.filter ?? '';
			}
			modal?.classList.add('open');
		});
	});

	modalClose?.addEventListener('click', () => modal?.classList.remove('open'));
	modal?.addEventListener('click', (e) => {
		if (e.target === modal) modal.classList.remove('open');
	});
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') modal?.classList.remove('open');
	});

	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('visible');
				} else {
					entry.target.classList.remove('visible');
				}
			});
		},
		{ threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
	);

	document.querySelectorAll('.reveal').forEach((el) => {
		observer.observe(el);
	});
</script>
